{
  "resources": [
    {
      "glob": "org/flywaydb/core/internal/version.txt"
    }
  ],
  "reflection": [
    {
      "type": {
        "proxy": [
          "com.example.service.SwissTravelAssistant"
        ]
      }
    },
    {
      "type": "com.example.tools.TravelTools",
      "allDeclaredConstructors": true,
      "allDeclaredMethods": true,
      "allDeclaredFields": true
    },
    {
      "type": { "pattern": "com.example.model.*" },
      "allDeclaredConstructors": true,
      "allDeclaredMethods": true,
      "allDeclaredFields": true
    },
    {
      "type": "org.flywaydb.core.internal.logging.slf4j.Slf4jLogCreator",
      "allDeclaredConstructors": true
    },
    {
      "type": "com.zaxxer.hikari.util.ConcurrentBag$IConcurrentBagEntry[]"
    },
    {
      "type": "com.fasterxml.jackson.databind.PropertyNamingStrategies$SnakeCaseStrategy",
      "allDeclaredConstructors": true
    },
    {
      "type": "dev.langchain4j.model.openai.internal.embedding.OpenAiEmbeddingDeserializer",
      "allDeclaredConstructors": true
    },
    {
      "type": { "pattern": "dev.langchain4j.model.openai.internal.embedding.*" },
      "allDeclaredConstructors": true,
      "allDeclaredMethods": true,
      "allDeclaredFields": true
    },
    {
      "type": { "pattern": "dev.langchain4j.model.openai.internal.chat.*" },
      "allDeclaredConstructors": true,
      "allDeclaredMethods": true,
      "allDeclaredFields": true
    },
    {
      "type": { "pattern": "dev.langchain4j.model.openai.internal.shared.*" },
      "allDeclaredConstructors": true,
      "allDeclaredMethods": true,
      "allDeclaredFields": true
    }
  ]
}
